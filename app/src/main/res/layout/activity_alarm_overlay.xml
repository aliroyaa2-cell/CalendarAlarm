<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0F14"
    android:layoutDirection="rtl">

    <TextView android:id="@+id/viewTopBar"
        android:layout_width="0dp" android:layout_height="4dp" android:text=""
        android:background="#5B6EF5"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView android:id="@+id/tvClock"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="00:00" android:textSize="54sp" android:textColor="#AAAAAA"
        android:gravity="center" android:paddingTop="48dp"
        app:layout_constraintTop_toBottomOf="@id/viewTopBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.cardview.widget.CardView android:id="@+id/cardEvent"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp" android:layout_marginTop="16dp"
        app:cardBackgroundColor="#1A1D2B" app:cardCornerRadius="18dp" app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvClock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="20dp">
            <TextView android:id="@+id/tvEventType"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="تقويم" android:textSize="11sp" android:textColor="#FFFFFF"
                android:paddingHorizontal="10dp" android:paddingVertical="4dp"
                android:layout_marginBottom="10dp" android:background="#5B6EF5" />
            <TextView android:id="@+id/tvEventTitle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="عنوان الحدث" android:textSize="22sp" android:textStyle="bold"
                android:textColor="#FFFFFF" android:paddingBottom="10dp" />
            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#2A2D3E" android:layout_marginBottom="10dp" />
            <TextView android:id="@+id/tvEventDetail"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="" android:textSize="14sp" android:textColor="#9099B5"
                android:lineSpacingMultiplier="1.4" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout android:id="@+id/layoutControls"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:orientation="vertical" android:paddingHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/cardEvent"
        app:layout_constraintBottom_toTopOf="@id/layoutDismissEdit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.5">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_gravity="center" android:text="تأجيل سريع"
            android:textSize="12sp" android:textColor="#9099B5" android:paddingBottom="10dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="10dp">
            <Button android:id="@+id/btnSnooze5"
                android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1"
                android:layout_marginEnd="6dp" android:text="5 دقائق"
                android:textSize="13sp" android:textColor="#FFFFFF" android:backgroundTint="#252840" />
            <Button android:id="@+id/btnSnooze10"
                android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1"
                android:layout_marginHorizontal="3dp" android:text="10 دقائق"
                android:textSize="13sp" android:textColor="#FFFFFF" android:backgroundTint="#252840" />
            <Button android:id="@+id/btnSnooze30"
                android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1"
                android:layout_marginStart="6dp" android:text="30 دقيقة"
                android:textSize="13sp" android:textColor="#FFFFFF" android:backgroundTint="#252840" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Spinner android:id="@+id/spinnerSnooze"
                android:layout_width="0dp" android:layout_height="50dp"
                android:layout_weight="1" android:layout_marginEnd="8dp" />
            <Button android:id="@+id/btnSnoozeAdvanced"
                android:layout_width="wrap_content" android:layout_height="50dp"
                android:text="تأجيل" android:textSize="14sp"
                android:textColor="#FFFFFF" android:backgroundTint="#5B6EF5" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout android:id="@+id/layoutDismissEdit"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:orientation="horizontal" android:paddingHorizontal="20dp" android:paddingBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <Button android:id="@+id/btnEdit"
            android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1"
            android:layout_marginEnd="8dp" android:text="تعديل"
            android:textSize="15sp" android:textColor="#8B9BFF" android:backgroundTint="#1A1D2B" />
        <Button android:id="@+id/btnDismiss"
            android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="2"
            android:text="إيقاف التنبيه" android:textSize="16sp" android:textStyle="bold"
            android:textColor="#FFFFFF" android:backgroundTint="#C0392B" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
